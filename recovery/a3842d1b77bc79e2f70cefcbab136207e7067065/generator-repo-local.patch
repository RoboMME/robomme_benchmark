+def _resolve_inside_workspace(path: Path, workspace_root: Path, label: str) -> Path:
+    """Resolve a path and reject any storage outside the declared workspace."""
+    resolved = path.expanduser().resolve()
+    if not resolved.is_relative_to(workspace_root):
+        raise ValueError(
+            f"{label} must stay inside workspace root {workspace_root}; got {resolved}"
+        )
+    return resolved
